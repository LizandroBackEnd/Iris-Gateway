// Iris Gateway — PostgreSQL (URL en prisma.config.ts → DATABASE_URL)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RefreshSession {
  id        String   @id @default(uuid())
  /// Identificador único del refresh JWT activo (claim `jti`)
  jti       String   @unique
  username  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
